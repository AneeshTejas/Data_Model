<configuration>
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <!-- Pattern: timestamp | level | logger (short) | message -->
            <pattern>%d{HH:mm:ss.SSS} | %-5level | %-30logger{30} | %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

    <!-- Show DEBUG logs only for our own code, not for libraries -->
    <logger name="com.streambridge" level="DEBUG"/>
</configuration>
